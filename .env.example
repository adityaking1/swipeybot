# Telegram Bot Token dari @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# MongoDB URI (MongoDB Atlas / Railway MongoDB / Render MongoDB)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/jodohbot

# Telegram ID admin untuk menerima notifikasi laporan
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Secret session (bisa diisi random string)
SESSION_SECRET=your_random_secret_here

# Port server (otomatis di Railway/Render)
PORT=8080
